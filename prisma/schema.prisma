generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String        @default("USER")
  accounts      Account[]
  jobSeeker     JobSeeker?
  organization  Organization?
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id            String           @id @default(cuid())
  userId        String           @unique
  companyName   String
  industry      String?
  website       String?
  logoUrl       String?
  sponsorStatus String           @default("No Sponsorship Data")
  contactEmail  String?
  description   String?
  location      String?
  companySize   String?
  jobPosts      JobPost[]
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  outreachSent  TalentOutreach[] @relation("OutreachFromOrg")
}

model JobSeeker {
  id                  String           @id @default(cuid())
  userId              String           @unique
  resumeUrl           String?
  bio                 String?
  firstName           String?
  lastName            String?
  headline            String?
  phone               String?
  city                String?
  avatarUrl           String?
  relocatable         String?
  isPublic            Boolean          @default(false)
  visaSponsorRequired Boolean          @default(false)
  portfolioUrl        String?
  githubUrl           String?
  linkedinUrl         String?
  gender              String?
  dob                 DateTime?
  differentlyAbled    String?
  veteranStatus       String?
  certifications      Certification[]
  education           Education[]
  experience          Experience[]
  interviews          Interview[]
  applications        JobApplication[]
  jobPreferences      JobPreference[]
  yearsOfExperience   Float?
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  languages           Language[]
  savedJobs           SavedJob[]
  skills              Skill[]
  outreachReceived    TalentOutreach[] @relation("OutreachToSeeker")
}

model JobPreference {
  id                String    @id @default(cuid())
  jobSeekerId       String
  preferredRole     String?
  preferredType     String?
  expectedSalaryMin Int?
  expectedSalaryMax Int?
  preferredLocation String?
  noticePeriod      String?
  availability      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  jobSeeker         JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String    @id @default(cuid())
  jobSeekerId String
  name        String
  proficiency String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model Experience {
  id               String    @id @default(cuid())
  jobSeekerId      String
  title            String
  company          String
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean   @default(false)
  empType          String
  location         String
  responsibilities String?
  jobSeeker        JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model Education {
  id            String    @id @default(cuid())
  jobSeekerId   String
  degree        String
  institution   String
  yearOfPassing Int
  grade         String?
  jobSeeker     JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model Certification {
  id          String    @id @default(cuid())
  jobSeekerId String
  name        String
  issuer      String
  year        Int
  url         String?
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model Language {
  id          String    @id @default(cuid())
  jobSeekerId String
  name        String
  proficiency String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model JobPost {
  id                 String           @id @default(cuid())
  orgId              String
  title              String
  description        String
  minSalary          Int?
  maxSalary          Int?
  visaSponsorBadge   String           @default("No Sponsorship Data")
  jobType            String           @default("FULL_TIME")
  locationType       String           @default("ONSITE")
  locationName       String?
  city               String?
  state              String?
  country            String?          @default("United Kingdom")
  currency           String           @default("GBP")
  salaryType         String           @default("YEARLY")
  benefits           String?
  requiredSkills     String?
  minExperience      Int?
  maxExperience      Int?
  education          String?
  certifications     String?
  responsibilities   String?
  openings           Int              @default(1)
  howToApply         String           @default("INTERNAL")
  externalUrl        String?
  contactEmail       String?
  isActive           Boolean          @default(true)
  closingDate        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  companyDescription String?
  companyName        String?
  industry           String?
  logoUrl            String?
  websiteUrl         String?
  equityBonus        String?
  interviews         Interview[]
  applications       JobApplication[]
  organization       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  savedJobs          SavedJob[]
}

model JobApplication {
  id          String    @id @default(cuid())
  jobPostId   String
  jobSeekerId String
  status      String    @default("Applied")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  jobPost     JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, jobSeekerId])
}

model Interview {
  id          String    @id @default(cuid())
  jobPostId   String
  jobSeekerId String
  scheduledAt DateTime
  type        String    @default("Video Call")
  round       String    @default("Round 1")
  status      String    @default("Scheduled")
  createdAt   DateTime  @default(now())
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  jobPost     JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id          String    @id @default(cuid())
  jobSeekerId String
  jobPostId   String
  createdAt   DateTime  @default(now())
  jobPost     JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  @@unique([jobSeekerId, jobPostId])
}

model TalentOutreach {
  id            String       @id @default(cuid())
  orgId         String
  jobSeekerId   String
  message       String
  interviewDate DateTime?
  status        String       @default("Pending")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  jobSeeker     JobSeeker    @relation("OutreachToSeeker", fields: [jobSeekerId], references: [id], onDelete: Cascade)
  organization  Organization @relation("OutreachFromOrg", fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, jobSeekerId])
}
